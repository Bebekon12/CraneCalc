@model List<CraneCalc.Domain.Models.Cargo>
@{
    ViewBag.Title = "CraneCalc - Заявка";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Styles {
    <link href="~/css/views/Calculation/calculation.css" rel="stylesheet" />
}

<div class="page-container">
    <div class="page-header">
        <h1>Заявка</h1>
        <button id="removeCartBtn" class="btn-delete-cart">
            <i class="fas fa-trash"></i> Удалить заявку
        </button>
    </div>
    <p>Дата: @DateTime.Now</p>
    <br/>
    
    <div class="crane-params-section">
        <h2>Параметры башенного крана</h2>
        <br/>
        <div class="crane-params-grid">
            <div class="param-group">
                <label>Грузоподъемность (т)</label>
                <input type="number" value="0" id="loadCapacity" />
            </div>
            <div class="param-group">
                <label>Высота подъема (м)</label>
                <input type="number" value="0" id="liftingHeight" />
            </div>
            <div class="param-group">
                <label>Вылет стрелы (м)</label>
                <input type="number" value="0" id="jibOutreach" />
            </div>
            <div class="param-group">
                <label>Скорость подъема (м/мин)</label>
                <input type="number" value="0" id="liftingSpeed" />
            </div>
            <div class="param-group result">
                <label>Общая производительность</label>
                <div class="result-value">0</div>
            </div>
        </div>
    </div>

    <div class="two-column-layout">
        <div class="cargo-column">
            <h2 class="column-title">Грузы в заявке</h2>
            <div class="request-items">
                @foreach (var item in Model)
                {
                    <div class="request-item">
                        <img src="@item.ImageUrl"
                             onerror="this.onerror=null; this.src='/img/default.jpg'"
                             alt="@item.Title" class="item-image" />
                        <div class="item-details">
                            <div class="text-in-card">
                                <div class="item-title">@item.Title</div>
                                <div class="item-specs">@item.Weight т | @item.Dimensions.ToString()</div>
                            </div>
                            <div class="form-result-item">
                                <div class="safety-comment">
                                    <label>Комментарий по технике безопасности:</label>
                                    <textarea class="item-comment" data-item-id="@item.Id"></textarea>
                                </div>
                                <div class="form-result">
                                    <div class="result-label">Производительность груза</div>
                                    <div class="result-value">0</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // Обработчик для кнопки удаления корзины
        const removeCartBtn = document.getElementById('removeCartBtn');
        if (removeCartBtn) {
            removeCartBtn.addEventListener('click', function() {
                removeCartBtn.disabled = true;
                removeCartBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Удаление...';
                fetch(`/remove-cart`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            window.location.href = data.redirectUrl;
                        } else {
                            removeCartBtn.disabled = false;
                            removeCartBtn.innerHTML = '<i class="fas fa-trash"></i> Удалить заявку';
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        removeCartBtn.disabled = false;
                        removeCartBtn.innerHTML = '<i class="fas fa-trash"></i> Удалить заявку';
                    });
            });
        }
        
        function updateTotals() {
            // Добавьте здесь логику обновления итоговых значений
            // Например, пересчет общего веса или стоимости
        }
    });
    </script>
}